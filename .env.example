# LLM Configuration
ANTHROPIC_API_KEY=your_key_here
AGENT_MODEL=claude-sonnet-4-6       # override to test different models
AGENT_MAX_ITERATIONS=5              # hard cap per task

# GitHub Integration (optional — only needed for PR opening)
GITHUB_TOKEN=your_token_here
GITHUB_REPO=owner/repo-name         # e.g. "mihirsavadi/my-project"

# Sandbox control
DRY_RUN=false                       # set to "true" to skip PR creation and Docker runs

# Observability
LOG_LEVEL=INFO
RESULTS_DIR=./results               # where task-level JSON results are written
